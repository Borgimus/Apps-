# Copy this to .env and fill in your values

# Database (auto-configured by docker-compose; override for external DB)
# DATABASE_URL=postgresql+asyncpg://trader:changeme@localhost:5432/ict_trading
POSTGRES_PASSWORD=changeme

# Broker credentials (optional — only needed for live signals from broker)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Alert channels (optional)
DISCORD_WEBHOOK=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP alerts (optional)
ICT_ALERT_SMTP_HOST=smtp.gmail.com
ICT_ALERT_SMTP_PORT=587
ICT_ALERT_SMTP_USER=
ICT_ALERT_SMTP_PASSWORD=
ICT_ALERT_EMAIL_FROM=
ICT_ALERT_EMAIL_TO=

# Safety: set to true ONLY for live trading
LIVE_TRADING_ENABLED=false
