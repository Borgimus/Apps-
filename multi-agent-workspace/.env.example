# ---------------------------------------------------------------------------
# Multi-Agent Workspace — environment template
# Copy to .env and fill in real values. NEVER commit real keys.
# ---------------------------------------------------------------------------

# SQLite database file (relative to prisma/). Postgres support is a roadmap item.
DATABASE_URL="file:./dev.db"

# --- Provider API keys (referenced by name from Model Configurations) -------
# Anthropic (Claude models)
ANTHROPIC_API_KEY=""

# OpenAI or any OpenAI-compatible gateway
OPENAI_API_KEY=""
# Override the OpenAI-compatible endpoint (OpenRouter, vLLM, LM Studio, ...)
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"

# Local models via Ollama (OpenAI-compatible mode)
# OLLAMA_BASE_URL="http://localhost:11434/v1"

# Placeholder provider slots (e.g. "Sol 5.6") — point these at a real
# OpenAI-compatible endpoint when one is available.
# SOL_BASE_URL=""
# SOL_API_KEY=""
