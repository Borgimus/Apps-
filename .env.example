# Copy this to .env and fill in your values

# Database (auto-configured by docker-compose; override for external DB)
# DATABASE_URL=postgresql+asyncpg://trader:changeme@localhost:5432/ict_trading
POSTGRES_PASSWORD=changeme

# ── Alpaca credentials ──────────────────────────────────────────────────────
# Get your keys at https://app.alpaca.markets → API Keys
# Paper trading (safe, recommended to start):
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Market data (free IEX tier covers US stocks/ETFs; "sip" requires paid plan)
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Alert channels (optional)
DISCORD_WEBHOOK=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Safety: set to true ONLY when you want live order execution
LIVE_TRADING_ENABLED=false
