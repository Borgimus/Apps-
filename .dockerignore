# Credentials and secrets — must never enter the image layer
.env
.env.*
!.env.example

# Session exports — may contain keys, trade data, or credentials in transcript
export_session_*.json

# Databases (large; rebuilt at runtime)
*.db
*.sqlite
*.sqlite3

# Log files
logs/
*.log

# Evaluation artifacts (contain trade data; not needed in image)
evaluation/
*.csv

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
wheels/

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
venv/
.venv/
env/
ENV/

# Editor and IDE state
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git metadata (not needed in image)
.git/
.github/

# Temporary files
tmp/
*.tmp
