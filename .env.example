# ── Trading Mode ──────────────────────────────────────────────────────────────
# WARNING: Setting LIVE_TRADING_ENABLED=true will place REAL orders with REAL money.
# Leave as false unless you have fully tested your strategies in paper mode.
LIVE_TRADING_ENABLED=false

# ── Active Broker ─────────────────────────────────────────────────────────────
# Options: alpaca | tradier | ibkr
BROKER=alpaca

# ── Alpaca ────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Paper trading base URL (default). Change to https://api.alpaca.markets for live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Tradier ───────────────────────────────────────────────────────────────────
TRADIER_ACCESS_TOKEN=your_tradier_access_token_here
# Sandbox: https://sandbox.tradier.com/v1  |  Live: https://api.tradier.com/v1
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# ── Interactive Brokers ───────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
# TWS paper trading port: 7497  |  Live port: 7496

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default): sqlite+aiosqlite:///./trading.db
# Postgres: postgresql+asyncpg://user:password@localhost/trading
DATABASE_URL=sqlite+aiosqlite:///./trading.db

# ── Kill Switch ───────────────────────────────────────────────────────────────
# Create this file to immediately halt all new order placement
KILL_SWITCH_FILE=./KILL_SWITCH

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/trading.log

# ── Dashboard API ─────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── Alerts — Slack ────────────────────────────────────────────────────────────
# Full incoming-webhook URL from https://api.slack.com/apps
# Leave blank to disable Slack alerts
ALERT_SLACK_WEBHOOK_URL=

# ── Alerts — Email ────────────────────────────────────────────────────────────
# Leave ALERT_EMAIL_FROM blank to disable email alerts
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=you@example.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
# Set to "false" to use SSL instead of STARTTLS
ALERT_SMTP_USE_TLS=true

# Minimum alert severity to deliver: info | warning | critical
ALERT_MIN_LEVEL=info

# ── Paper Evaluation Mode ─────────────────────────────────────────────────────
# When true: enables pre/post session checklists, daily reports, and ledger.
# Incompatible with LIVE_TRADING_ENABLED=true.
PAPER_EVALUATION_MODE=false

# Where to write daily evaluation reports (JSON + Markdown)
EVALUATION_OUTPUT_DIR=./evaluation

# Cumulative ledger file (updated after every session)
EVALUATION_LEDGER_FILE=./evaluation/ledger.json

# ── Entry / Exit Limit Price Modes ────────────────────────────────────────────
# How the entry limit price is computed from the bid/ask quote.
# Options: bid | mid | ask | marketable_limit
# Default: mid  (balanced; likely to fill slowly or not at all on wide spreads)
# Recommended for evaluation: marketable_limit (fills like a market order)
OPTIONS_ENTRY_LIMIT_PRICE_MODE=mid
OPTIONS_EXIT_LIMIT_PRICE_MODE=mid

# In marketable_limit mode: how far above the ask to set the limit.
# Expressed as a fraction of spread width.  0.01 = 1% of spread above ask.
OPTIONS_ENTRY_MARKETABLE_OFFSET_PCT=0.01
OPTIONS_EXIT_MARKETABLE_OFFSET_PCT=0.01

# ── Realistic Fill Test Mode ──────────────────────────────────────────────────
# When true: forces marketable_limit pricing, SPY-only, qty=1, detailed telemetry.
# Requires a paper account.  Hard-stops if spread exceeds FILL_TEST_MAX_SPREAD_PCT.
REALISTIC_FILL_TEST_MODE=false

# How long (seconds) before an unfilled entry order is cancelled as stale.
ENTRY_ORDER_TIMEOUT_SECS=120
EXIT_ORDER_TIMEOUT_SECS=120

# Maximum allowed spread (ask-bid)/mid before aborting a contract in fill-test mode.
FILL_TEST_MAX_SPREAD_PCT=0.20

# ── Universe / Scanning ───────────────────────────────────────────────────────
# mode: manual (use config/ticker_universe.yaml) | off (use --symbol args only)
UNIVERSE_MODE=manual

# Path to the universe YAML file (relative to project root)
UNIVERSE_FILE=./config/ticker_universe.yaml

# Maximum symbols to scan per cycle (from the universe list)
UNIVERSE_MAX_SYMBOLS_PER_SCAN=10

# Maximum symbols that may be simultaneously active in the session
UNIVERSE_MAX_ACTIVE_SYMBOLS=3

# Maximum distinct symbols traded in a single day
UNIVERSE_MAX_SYMBOLS_TRADED_PER_DAY=1

# Maximum open option positions at any one time
UNIVERSE_MAX_ACTIVE_POSITIONS=1

# Minimum candidate score (0-100) required to proceed to Alpaca confirmation
UNIVERSE_MIN_SCAN_SCORE=40.0

# How often (minutes) to re-run the scan during the session
UNIVERSE_SCAN_INTERVAL_MINUTES=30
