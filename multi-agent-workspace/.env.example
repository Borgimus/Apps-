# ---------------------------------------------------------------------------
# Multi-Agent Workspace — environment template
# Copy to .env and fill in real values. NEVER commit real keys.
# ---------------------------------------------------------------------------

# SQLite database file (relative to prisma/). Postgres support is a roadmap item.
DATABASE_URL="file:./dev.db"

# --- Provider API keys (referenced by name from Model Configurations) -------
# Anthropic (Claude models)
ANTHROPIC_API_KEY=""

# OpenAI or any OpenAI-compatible gateway
OPENAI_API_KEY=""
# Override the OpenAI-compatible endpoint (OpenRouter, vLLM, LM Studio, ...)
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"

# Local models via Ollama (OpenAI-compatible mode)
# OLLAMA_BASE_URL="http://localhost:11434/v1"

# Placeholder provider slots (e.g. "Sol 5.6") — point these at a real
# OpenAI-compatible endpoint when one is available.
# SOL_BASE_URL=""
# SOL_API_KEY=""

# --- GitHub App integration (optional) ---------------------------------------
# Lets agents read the repository freely and propose changes on agent/*,
# agents/* or feature/* branches — every mutation stops for your approval.
# The private key stays on disk, is read server-side only, and is never
# stored in the database or sent to a browser or model.
# GITHUB_APP_ID=""
# GITHUB_INSTALLATION_ID=""
# GITHUB_APP_PRIVATE_KEY_PATH="./github-app-key.pem"
# GITHUB_REPOSITORY="owner/repo"


# --- Read-only trading dashboard --------------------------------------------
# Server-side URL for the Python FastAPI trading API. Keep it on localhost
# unless you provide a private, authenticated network path.
TRADING_API_URL="http://127.0.0.1:8000"
